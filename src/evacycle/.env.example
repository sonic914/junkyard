# =============================================================
# EVACYCLE 환경 변수 예시
# 실제 사용 시 .env 파일로 복사 후 값 채울 것
# =============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001

# ── Database (PostgreSQL) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=evacycle
DB_USER=evacycle_user
DB_PASSWORD=change_me_in_production

# ── Cache (Redis) ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Object Storage (MinIO) ───────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=evacycle-files
MINIO_USE_SSL=false

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=super_secret_change_me
JWT_EXPIRES_IN=7d

# ── Blockchain ───────────────────────────────────────────────
BLOCKCHAIN_NETWORK=polygon_mumbai
BLOCKCHAIN_RPC_URL=https://rpc-mumbai.maticvigil.com
BLOCKCHAIN_PRIVATE_KEY=0x_your_deployer_private_key

# ── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=EVACYCLE
