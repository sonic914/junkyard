# ───────────────────────────────────────────────
# EVACYCLE — Production Environment Variables
# ───────────────────────────────────────────────
# 복사하여 .env.production으로 사용, 실제 값으로 교체
# cp .env.production.template .env.production

# ── Application ──
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://app.evacycle.com

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:5432/evacycle
DB_HOST=<HOST>
DB_PORT=5432
DB_NAME=evacycle
DB_USER=<USER>
DB_PASSWORD=<PASSWORD>

# ── Redis ──
REDIS_HOST=<HOST>
REDIS_PORT=6379
REDIS_PASSWORD=<PASSWORD>
REDIS_DB=0

# ── JWT ──
JWT_ACCESS_SECRET=<64자_이상_랜덤_문자열>
JWT_REFRESH_SECRET=<64자_이상_랜덤_문자열>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── OTP ──
OTP_TTL_SECONDS=300

# ── SMTP (이메일 발송) ──
SMTP_HOST=<smtp.provider.com>
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASS=<smtp-password>
SMTP_FROM=no-reply@evacycle.com

# ── MinIO / S3 (파일 저장) ──
MINIO_ENDPOINT=<minio-host>
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=<access-key>
MINIO_SECRET_KEY=<secret-key>
MINIO_BUCKET=evacycle

# ── Blockchain (선택) ──
# BLOCKCHAIN_RPC_URL=<rpc-url>
# BLOCKCHAIN_PRIVATE_KEY=<private-key>
# BLOCKCHAIN_CONTRACT_ADDRESS=<contract-address>
# BLOCKCHAIN_NETWORK_ID=<network-id>
