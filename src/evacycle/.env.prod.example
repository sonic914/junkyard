# ─── EVACYCLE 프로덕션 환경변수 ────────────────────────────────────────────────
# cp .env.prod.example .env.prod  →  값 설정 후 사용
# ⚠️  .env.prod는 절대 Git에 커밋하지 마세요!

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=evacycle
POSTGRES_USER=evacycle_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=evacycle
MINIO_PUBLIC_URL=https://nas.yourdomain.com:9000

# ─── CORS / 외부 접근 URL ─────────────────────────────────────────────────────
# 프론트엔드 도메인 (NAS 외부 IP 또는 도메인)
CORS_ORIGIN=https://evacycle.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.evacycle.yourdomain.com

# ─── 포트 (NAS 포트 포워딩 기준) ─────────────────────────────────────────────
API_PORT=3000
WEB_PORT=3001
MINIO_CONSOLE_PORT=9001
