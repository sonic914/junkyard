// ─────────────────────────────────────────────────────────
// EVACYCLE Prisma Schema — Phase 1 (Arlo 설계서 기준)
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────
// Enums
// ────────────────────────────────────────────────────────

enum OrgType {
  JUNKYARD
  INTAKE_JUNKYARD
  HUB
  BUYER
  PLATFORM
}

enum UserRole {
  OWNER
  JUNKYARD
  INTAKE_JUNKYARD
  HUB
  BUYER
  ADMIN
}

enum CaseStatus {
  DRAFT
  SUBMITTED
  IN_TRANSIT
  RECEIVED
  GRADING
  ON_SALE
  SOLD
  SETTLED
  CANCELLED
}

enum EventType {
  CASE_CREATED
  CASE_SUBMITTED
  COC_SIGNED
  INTAKE_CONFIRMED
  GRADING_SUBMITTED
  LISTING_PUBLISHED
  PURCHASE_COMPLETED
  SETTLEMENT_CREATED
  SETTLEMENT_APPROVED
  SETTLEMENT_PAID
  SETTLEMENT_REJECTED
  CASE_CANCELLED
}

enum SettleStatus {
  PENDING
  APPROVED
  PAID
  DISPUTED
}

// ────────────────────────────────────────────────────────
// CP4 Enums (M0+Δ 정산)
// ────────────────────────────────────────────────────────

enum SettlementType {
  M0          // 최소보장금 (Conservative: PURCHASE_COMPLETED 트리거)
  DELTA_1     // 그레이딩 완료 후 추가 정산
  DELTA_2     // 판매 완료 후 최종 정산
}

enum SettlementStatus {
  PENDING    // 생성됨, 승인 대기
  APPROVED   // 관리자 승인 완료
  PAID       // 지급 완료
  REJECTED   // 거부됨
}

enum FileType {
  IMAGE
  DOCUMENT
}

enum FileStatus {
  PENDING
  CONFIRMED
  DELETED
}

// ────────────────────────────────────────────────────────
// CP3 Enums (그레이딩 + Lot + Listing)
// ────────────────────────────────────────────────────────

enum PartType {
  BATTERY
  MOTOR
  INVERTER
  BODY
  OTHER
}

enum ReuseGrade {
  A    // 즉시 재사용 가능
  B    // 경미한 보수 후 재사용
  C    // 제한적 재사용 (특정 용도)
  D    // 재사용 불가
}

enum RecycleGrade {
  R1   // 고순도 자원 회수 가능
  R2   // 일반 자원 회수
  R3   // 회수 어려움 / 처리 비용 발생
}

enum RoutingDecision {
  REUSE      // 재사용 경로 → Lot 생성
  RECYCLE    // 재활용 경로 → Lot 생성
  DISCARD    // 폐기 → Lot 미생성
}

enum LotStatus {
  PENDING    // 생성됨, 미등록
  ON_SALE    // 판매 등록됨
  SOLD       // 구매 완료
  SETTLED    // 정산 완료
}

enum ListingStatus {
  DRAFT      // 초안
  ACTIVE     // 판매 중
  SOLD       // 판매 완료
  CANCELLED  // 취소됨
}

// ────────────────────────────────────────────────────────
// Organization (조직)
// ────────────────────────────────────────────────────────
model Organization {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  type      OrgType
  bizNo     String   @db.VarChar(20)
  address   String?
  phone     String?  @db.VarChar(20)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  ownedCases  VehicleCase[] @relation("CaseOwnerOrg")
  intakeCases VehicleCase[] @relation("CaseIntakeOrg")
  hubCases    VehicleCase[] @relation("CaseHubOrg")
  settlements Settlement[]
}

// ────────────────────────────────────────────────────────
// User (사용자)
// ────────────────────────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  orgId        String
  email        String    @unique @db.VarChar(255)
  name         String    @db.VarChar(100)
  role         UserRole
  otpSecret    String?   @db.VarChar(100)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org          Organization  @relation(fields: [orgId], references: [id])
  createdCases VehicleCase[]
  ledgerEvents EventLedger[]
  approvedSettlements Settlement[]
  uploadedFiles CaseFile[]
  gradings          Grading[]
  purchasedListings Listing[]
  settlementsAsYard     NewSettlement[] @relation("NewSettlementYardUser")
  settlementsApproved   NewSettlement[] @relation("NewSettlementApprover")
}

// ────────────────────────────────────────────────────────
// VehicleCase (차량 케이스)
// ────────────────────────────────────────────────────────
model VehicleCase {
  id           String     @id @default(uuid())
  orgId        String
  intakeOrgId  String?
  hubOrgId     String?
  createdBy    String
  caseNo       String     @unique @db.VarChar(30)
  vin          String?    @unique @db.VarChar(17)
  vehicleMaker String     @db.VarChar(50)
  vehicleModel String     @db.VarChar(50)
  vehicleYear  Int        @db.SmallInt
  status       CaseStatus @default(DRAFT)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ownerOrg   Organization  @relation("CaseOwnerOrg", fields: [orgId], references: [id])
  intakeOrg  Organization? @relation("CaseIntakeOrg", fields: [intakeOrgId], references: [id])
  hubOrg     Organization? @relation("CaseHubOrg", fields: [hubOrgId], references: [id])
  creator    User          @relation(fields: [createdBy], references: [id])
  ledger     EventLedger[]
  files      CaseFile[]
  settlement  Settlement?
  settlements NewSettlement[]
  gradings    Grading[]
  lots        DerivedLot[]

  @@index([orgId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// ────────────────────────────────────────────────────────
// EventLedger (이벤트 원장 — 불변 해시 체인)
// ────────────────────────────────────────────────────────
model EventLedger {
  id        String    @id @default(uuid())
  caseId    String
  actorId   String
  seq       Int
  eventType EventType
  payload   Json
  prevHash  String    @db.VarChar(64)
  selfHash  String    @db.VarChar(64)
  createdAt DateTime

  case  VehicleCase @relation(fields: [caseId], references: [id])
  actor User        @relation(fields: [actorId], references: [id])
  files CaseFile[]

  @@unique([caseId, seq])
  @@index([caseId])
  @@index([selfHash])
}

// ────────────────────────────────────────────────────────
// Settlement (정산)
// ────────────────────────────────────────────────────────
model Settlement {
  id          String       @id @default(uuid())
  caseId      String       @unique
  orgId       String
  approvedBy  String?
  grossAmount Decimal      @db.Decimal(12, 2)
  costAmount  Decimal      @db.Decimal(12, 2)
  feeRate     Decimal      @db.Decimal(5, 4)
  feeAmount   Decimal      @db.Decimal(12, 2)
  netAmount   Decimal      @db.Decimal(12, 2)
  currency    String       @default("KRW") @db.Char(3)
  status      SettleStatus @default(PENDING)
  settledAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  case     VehicleCase  @relation(fields: [caseId], references: [id])
  org      Organization @relation(fields: [orgId], references: [id])
  approver User?        @relation(fields: [approvedBy], references: [id])
}

// ────────────────────────────────────────────────────────
// CaseFile (파일 업로드 메타데이터)
// ────────────────────────────────────────────────────────
model CaseFile {
  id          String      @id @default(uuid())
  caseId      String
  eventId     String?
  fileName    String
  fileType    FileType
  contentType String
  objectKey   String
  fileSize    Int?
  status      FileStatus  @default(PENDING)
  uploadedBy  String
  uploadedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  case     VehicleCase  @relation(fields: [caseId], references: [id])
  event    EventLedger? @relation(fields: [eventId], references: [id])
  uploader User         @relation(fields: [uploadedBy], references: [id])

  @@index([caseId])
  @@index([eventId])
  @@index([status])
}

// ────────────────────────────────────────────────────────
// GradingRule (그레이딩 기준 — partType별 조건)
// ────────────────────────────────────────────────────────
model GradingRule {
  id                String    @id @default(uuid())
  partType          PartType
  reuseConditions   Json      // { "A": {"maxAge":5,"minCapacity":80}, "B": {...}, ... }
  recycleConditions Json      // { "R1": {"minPurity":90}, "R2": {...}, ... }
  version           Int       @default(1)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([partType, version])
  @@index([partType, isActive])
}

// ────────────────────────────────────────────────────────
// Grading (그레이딩 결과)
// ────────────────────────────────────────────────────────
model Grading {
  id               String           @id @default(uuid())
  caseId           String
  actorId          String
  partType         PartType
  reuseGrade       ReuseGrade
  recycleGrade     RecycleGrade
  routingDecision  RoutingDecision
  notes            String?
  ruleSnapshot     Json?            // 적용된 GradingRule 스냅샷 (감사용)
  createdAt        DateTime         @default(now())

  case  VehicleCase @relation(fields: [caseId], references: [id])
  actor User        @relation(fields: [actorId], references: [id])

  @@index([caseId])
}

// ────────────────────────────────────────────────────────
// DerivedLot (파생 Lot — Case에서 추출된 부품/자원)
// ────────────────────────────────────────────────────────
model DerivedLot {
  id               String           @id @default(uuid())
  caseId           String
  lotNo            String           @unique @db.VarChar(30)
  partType         PartType
  routingDecision  RoutingDecision
  reuseGrade       ReuseGrade?
  recycleGrade     RecycleGrade?
  quantity         Int              @default(1)
  weightKg         Decimal          @db.Decimal(8, 2)
  status           LotStatus        @default(PENDING)
  description      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  case        VehicleCase     @relation(fields: [caseId], references: [id])
  listing     Listing?
  settlements NewSettlement[]

  @@index([caseId])
  @@index([status])
  @@index([partType])
}

// ────────────────────────────────────────────────────────
// Listing (판매 등록 — MVP: 고정가만)
// ────────────────────────────────────────────────────────
model Listing {
  id           String        @id @default(uuid())
  lotId        String        @unique
  type         String        @default("FIXED_PRICE") @db.VarChar(20)
  price        Decimal       @db.Decimal(12, 2)
  currency     String        @default("KRW") @db.Char(3)
  status       ListingStatus @default(DRAFT)
  buyerId      String?
  purchasedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  lot   DerivedLot @relation(fields: [lotId], references: [id])
  buyer User?      @relation(fields: [buyerId], references: [id])

  @@index([status])
  @@index([buyerId])
}

// ────────────────────────────────────────────────────────
// SettlementRule (정산 기준 — partType별 M0 기본금 + Delta 비율)
// ────────────────────────────────────────────────────────
model SettlementRule {
  id              String    @id @default(uuid())
  partType        PartType
  m0BaseAmount    Decimal   @db.Decimal(12, 2)  // M0 기본 정산금
  deltaRatio      Decimal   @db.Decimal(5, 2)   // 기본 Δ비율 (15.00 = 15%)
  gradeBonusMap   Json?     // { "A": 20.0, "B": 10.0, "C": 5.0, "D": 0.0 } (%)
  platformFeeRate Decimal   @db.Decimal(5, 4) @default(0.0500)  // 플랫폼 수수료율
  currency        String    @default("KRW") @db.Char(3)
  version         Int       @default(1)
  isActive        Boolean   @default(true)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([partType, version])
  @@index([partType, isActive])
}

// ────────────────────────────────────────────────────────
// NewSettlement (CP4 M0+Δ 정산 내역)
// ────────────────────────────────────────────────────────
model NewSettlement {
  id               String           @id @default(uuid())
  caseId           String
  lotId            String?                          // DELTA_1/DELTA_2일 때 설정
  yardUserId       String                           // 정산 대상 (수거업체 담당자)
  type             SettlementType                   // M0, DELTA_1, DELTA_2
  status           SettlementStatus @default(PENDING)

  // 정산 금액 상세
  grossAmount      Decimal          @db.Decimal(12, 2)  // 총액 (계산 기반)
  feeRate          Decimal          @db.Decimal(5, 4)   // 플랫폼 수수료율
  feeAmount        Decimal          @db.Decimal(12, 2)  // 수수료 금액
  amount           Decimal          @db.Decimal(12, 2)  // 최종 지급액

  currency         String           @default("KRW") @db.Char(3)

  // 계산 근거
  ruleSnapshot     Json?                            // 적용된 SettlementRule 스냅샷
  calcDetail       Json?                            // 상세 계산 내역 (감사용)
  triggeredByEvent String?                          // 트리거한 EventLedger.id

  // 승인/거부
  notes            String?
  approvedBy       String?
  approvedAt       DateTime?
  paidAt           DateTime?
  rejectedReason   String?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  case       VehicleCase @relation(fields: [caseId], references: [id])
  lot        DerivedLot? @relation(fields: [lotId], references: [id])
  yardUser   User        @relation("NewSettlementYardUser", fields: [yardUserId], references: [id])
  approver   User?       @relation("NewSettlementApprover", fields: [approvedBy], references: [id])

  @@index([caseId])
  @@index([lotId])
  @@index([yardUserId])
  @@index([status])
  @@index([type])
  @@index([createdAt(sort: Desc)])
}
