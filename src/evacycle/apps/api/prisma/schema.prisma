// ─────────────────────────────────────────────────────────
// EVACYCLE Prisma Schema — Phase 1 (Arlo 설계서 기준)
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────
// Enums
// ────────────────────────────────────────────────────────

enum OrgType {
  JUNKYARD
  INTAKE_JUNKYARD
  HUB
  BUYER
  PLATFORM
}

enum UserRole {
  OWNER
  JUNKYARD
  INTAKE_JUNKYARD
  HUB
  BUYER
  ADMIN
}

enum CaseStatus {
  DRAFT
  SUBMITTED
  IN_TRANSIT
  RECEIVED
  GRADING
  ON_SALE
  SOLD
  SETTLED
  CANCELLED
}

enum EventType {
  CASE_CREATED
  CASE_SUBMITTED
  COC_SIGNED
  INTAKE_CONFIRMED
  GRADING_SUBMITTED
  LISTING_PUBLISHED
  PURCHASE_COMPLETED
  SETTLEMENT_CREATED
  SETTLEMENT_APPROVED
  CASE_CANCELLED
}

enum SettleStatus {
  PENDING
  APPROVED
  PAID
  FAILED
}

// ────────────────────────────────────────────────────────
// Organization (조직)
// ────────────────────────────────────────────────────────
model Organization {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  type      OrgType
  bizNo     String   @db.VarChar(20)
  address   String?
  phone     String?  @db.VarChar(20)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  ownedCases  VehicleCase[] @relation("CaseOwnerOrg")
  intakeCases VehicleCase[] @relation("CaseIntakeOrg")
  hubCases    VehicleCase[] @relation("CaseHubOrg")
  settlements Settlement[]
}

// ────────────────────────────────────────────────────────
// User (사용자)
// ────────────────────────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  orgId        String
  email        String    @unique @db.VarChar(255)
  name         String    @db.VarChar(100)
  role         UserRole
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org          Organization  @relation(fields: [orgId], references: [id])
  createdCases VehicleCase[]
  ledgerEvents EventLedger[]
  approvedSettlements Settlement[]
}

// ────────────────────────────────────────────────────────
// VehicleCase (차량 케이스)
// ────────────────────────────────────────────────────────
model VehicleCase {
  id           String     @id @default(uuid())
  orgId        String
  intakeOrgId  String?
  hubOrgId     String?
  createdBy    String
  caseNo       String     @unique @db.VarChar(30)
  vin          String?    @db.VarChar(17)
  vehicleMaker String     @db.VarChar(50)
  vehicleModel String     @db.VarChar(50)
  vehicleYear  Int        @db.SmallInt
  status       CaseStatus @default(DRAFT)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ownerOrg   Organization  @relation("CaseOwnerOrg", fields: [orgId], references: [id])
  intakeOrg  Organization? @relation("CaseIntakeOrg", fields: [intakeOrgId], references: [id])
  hubOrg     Organization? @relation("CaseHubOrg", fields: [hubOrgId], references: [id])
  creator    User          @relation(fields: [createdBy], references: [id])
  ledger     EventLedger[]
  settlement Settlement?

  @@index([orgId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// ────────────────────────────────────────────────────────
// EventLedger (이벤트 원장 — 불변 해시 체인)
// ────────────────────────────────────────────────────────
model EventLedger {
  id        String    @id @default(uuid())
  caseId    String
  actorId   String
  seq       Int
  eventType EventType
  payload   Json
  prevHash  String    @db.VarChar(64)
  selfHash  String    @db.VarChar(64)
  createdAt DateTime

  case  VehicleCase @relation(fields: [caseId], references: [id])
  actor User        @relation(fields: [actorId], references: [id])

  @@unique([caseId, seq])
  @@index([caseId])
  @@index([selfHash])
}

// ────────────────────────────────────────────────────────
// Settlement (정산)
// ────────────────────────────────────────────────────────
model Settlement {
  id          String       @id @default(uuid())
  caseId      String       @unique
  orgId       String
  approvedBy  String?
  grossAmount Decimal      @db.Decimal(12, 2)
  costAmount  Decimal      @db.Decimal(12, 2)
  feeRate     Decimal      @db.Decimal(5, 4)
  feeAmount   Decimal      @db.Decimal(12, 2)
  netAmount   Decimal      @db.Decimal(12, 2)
  currency    String       @default("KRW") @db.Char(3)
  status      SettleStatus @default(PENDING)
  settledAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  case     VehicleCase  @relation(fields: [caseId], references: [id])
  org      Organization @relation(fields: [orgId], references: [id])
  approver User?        @relation(fields: [approvedBy], references: [id])
}
