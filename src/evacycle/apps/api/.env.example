# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://evacycle_user:change_me_in_production@localhost:5432/evacycle

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=local-test-secret-change-me
JWT_REFRESH_SECRET=local-test-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO (오브젝트 스토리지) ─────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=evacycle
MINIO_USE_SSL=false

# ─── 서버 ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001
