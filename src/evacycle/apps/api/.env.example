# ── App ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# ── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL="postgresql://evacycle_user:change_me_in_production@localhost:5432/evacycle?schema=public"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=evacycle
DB_USER=evacycle_user
DB_PASSWORD=change_me_in_production

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── MinIO (Object Storage) ─────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=evacycle
MINIO_USE_SSL=false

# ── Blockchain ─────────────────────────────────────────────
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_NETWORK_ID=1
